# EditorConfig helps maintain consistent coding styles across different IDEs
# https://editorconfig.org

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{ts,js,json,md,yml,yaml}]
indent_style = tab
indent_size = 3
max_line_length = 120
